<!-- 
  Partial: product-view-info
  Renders full product detail view
  Expects: productInfo object from /product/:sku route
-->

<% const productName = ['Keychrome',
    productInfo.series,
    productInfo.version,
    productInfo.switchtype,
    productInfo.switch,
    productInfo.type].filter(Boolean); %>

<!-- Product container: image on left, details on right (desktop) -->
<article id="product-container">
    <img 
        class="detailed-img" 
        onerror="this.src='https://placehold.co/400x300?text=No+Image'" 
        src="<%= productInfo.image_source %>" 
        alt="<%= productInfo.description %>">

    <div>
         <!-- Product top: status badges, name, SKU, price -->
        <section id="product-top">

            <!-- Status badges: conditionally rendered based on product flags and stock -->
            <div class="conditional-tag">
                <% if (productInfo.discountavailable) { %>
                    <div data-status="discount-available">
                        <i class="fa-solid fa-tag" style="font-size: 12px; color: var(--white)"></i>
                        <p class="data-tag">SALE</p>
                    </div>
                <% } %>
    
                <% if (parseInt(productInfo.stock_amount) === 0 || productInfo.stock_amount  === null) { %>
                    <div data-status="sold-out">
                        <i class="fa-solid fa-store-slash" style="font-size: 12px; color: var(--white)"></i>
                        <p class="data-tag">SOLD OUT</p>
                    </div>
                <% } %>

                <% if (productInfo.newarrival) { %>
                    <div data-status="new-arrival">
                        <i class="fa-solid fa-fire shake-vertical-subtle" style="font-size: 12px; color: var(--white)"></i>
                        <p class="data-tag">NEW</p>
                    </div>
                <% } %>
            </div>
            
            <!-- Product name, SKU, and price -->

            <h5 style="text-align: left;">
                <%= `${productName.join(" ")}` %>
            </h5>

            <p class="label">
                SKU: <%= `${productInfo.sku}` %>
            </p>

            <p style="color: var(--orange)" class="data-price">
                $<%= `${productInfo.price}` %>
            </p>
    
            <hr class="divider">
        </section>
        
        <!-- Product mid: specs and description, only renders fields that exist -->
        <section id="product-mid">
            <% if (productInfo.type) { %>
                <div>
                    <p class="label">Type</p>
                    <p class="product-info">
                        <%= `${productInfo.type}` %>
                    </p>
                </div>    
            <% } %>
    
            <% if (productInfo.version) { %>
                <div>   
                    <p class="label">Version</p>
                    <p class="product-info">
                        <%= `${productInfo.version}` %>
                    </p>
                </div>
            <% } %>
        
            <% if (productInfo.layoutversion) { %>
                <div>
                    <p class="label">Layout Version</p>
                    <p class="product-info">
                        <%= `${productInfo.layoutversion}` %>
                    </p>
                </div>   
            <% } %>
    
            <% if (productInfo.switch) { %>
                <div>
                    <p class="label">Switches</p>
                    <p class="product-info">
                        <%= `${productInfo.switch}` %>
                    </p>
                </div>
            <% } %>
            
            <% if (productInfo.switchtype) { %>
                <div>
                    <p class="label">Switch Type</p>
                    <p class="product-info">
                        <%= `${productInfo.switchtype}` %>
                    </p>
                </div>
            <% } %>
    
            <% if (productInfo.sensor) { %>
                <div>
                    <p class="label">Sensor</p>
                    <p class="product-info">
                        <%= `${productInfo.sensor}` %>
                    </p>
                </div>
            <% } %>
    
            <hr class="divider">
    
            <!-- Product description -->
            <% if (productInfo.description) { %>
                <p>
                    <%= `${productInfo.description}` %>
                </p>
            <% } %>
    
            <!-- Add to cart: quantity input and submit button -->
            <div class="product-bottom">
                <div>
                    <label for="n_item_cart"></label>
                    <input class="add-to-cart-input" type="number" id="n_item_cart" name="n_item_cart" value="0" title="number of carts" min="0" max="5">
                </div>
                <button type="submit" class="cta">Add to cart</button>
            </div>
        </section>
    </div>
    
</article>