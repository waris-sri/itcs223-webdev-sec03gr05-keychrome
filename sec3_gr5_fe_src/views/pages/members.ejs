<%- include('../partials/header') %>
<!-- Header partial: nav, stylesheets, fonts -->

<body>
  <main>

    <span class="img-thumbnail" style="width: fit-content; height: fit-content; padding: 8px; margin: auto;">
      <span class="corner-lg tl"></span><span class="corner-lg tr"></span>
      <span class="corner-lg bl"></span><span class="corner-lg br"></span>
      <i class="fa-solid fa-users" style="color: var(--orange); font-size: xx-large; padding-top: 4px; padding-bottom: 4px;"></i>
    </span>

    <h1 style="margin-block: 32px">Team Members</h1>

    <!-- Members grid: renders one card per member passed from fe.js -->
    <section class="members-grid">
      <% members.forEach(member=> { %>

      <!-- Individual member card -->
      <article class="member-card">

        <!-- Profile image -->
        <div class="member-img-wrapper">
          <img src="../public/img/profiles/<%= member.img %>.png" alt="<%= member.name %>" class="member-img" />
          <span class="corner-lg tl"></span><span class="corner-lg tr"></span>
          <span class="corner-lg bl"></span><span class="corner-lg br"></span>
        </div>

        <!-- Member name, role, and conditional social links -->
        <div class="member-info">
          <p class="body-lg" style="font-weight: 700;">
            <%= member.name %>
          </p>

          <p style="color: var(--black)">
            <%= member.role %>
          </p>

          <p style="color: var(--black); margin-top: 8px">
            Socials:
            <% if (member.instagram) { %>
              <a href="<%= (member.instagram) %>" style="color: var(--instagram)" class="member-a-tag"><i class="fa-brands fa-square-instagram"></i></a>
            <% } %>

            <% if (member.linkedin) { %>
              <a href="<%= (member.linkedin) %>" style="color: var(--linkedin)" class="member-a-tag"><i class="fa-brands fa-linkedin"></i></a>
            <% } %>

            <% if (member.github) { %>
              <a href="<%= (member.github) %>" style="color: var(--black)" class="member-a-tag"><i class="fa-brands fa-github"></i></a>
            <% } %>
          </p>
        </div>

      </article>
      <% }) %>
    </section>

  </main>
</body>

<!-- Footer partial: footer links -->
<%- include('../partials/footer') %>