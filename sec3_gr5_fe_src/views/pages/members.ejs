<%- include('../partials/header') %>

<body>
  <main>
    <h1>Team Members</h1>

    <div class="members-grid">
      <% members.forEach(member => { %>
      <div class="member-card">
        <div class="member-img-wrapper">
          <img
            src="../public/img/profiles/<%= member.img %>.png"
            alt="<%= member.name %>"
            class="member-img"
          />
          <span class="corner-sm tl"></span><span class="corner-sm tr"></span>
          <span class="corner-sm bl"></span><span class="corner-sm br"></span>
        </div>
        <div class="member-info">
          <p class="body-lg" style="font-weight: 700;"><%= member.name %></p>
          <p style="color: var(--black)"><%= member.role %></p>
        </div>
      </div>
      <% }) %>
    </div>
  </main>
</body>

<%- include('../partials/footer') %>
